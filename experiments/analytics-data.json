  "per_cli_driving_recipe": {
    "claude": {
      "submit_key_sequence": "send-keys -l TEXT then send-keys Enter (two-step)",
      "submit_variant": "one-shot 'TEXT Enter' also works but two-step preferred",
      "readiness_signals": [
        "! grep -q 'esc to interrupt' (generation in progress marker absent)",
        "grep -qE '^❯[[:space:]]*$' (empty prompt line)",
        "grep -q '? for shortcuts' (footer in steady state)"
      ],
      "readiness_strategy": "three-signal AND; response-token strategy preferred for test prompts",
      "init_gates": [
        "pre-seed ~/.claude.json with hasCompletedOnboarding:true + projects.workspace.hasTrustDialogAccepted:true",
        "set installMethod: npm-global (not native)",
        "tmux new-session -d -x 200 -y 50 (explicit size)"
      ],
      "auth_mount": {
        "required": ["~/.claude/ (dir, for .credentials.json OAuth tokens)", "~/.claude.json (file, for metadata + onboarding markers)"],
        "token_file": "~/.claude/.credentials.json",
        "metadata_file": "~/.claude.json",
        "driver_synthesizes_json": true
      },
      "first_prompt_quirk": "none — two-step works immediately after init gates"
    },
    "codex": {
      "submit_key_sequence": "TEXT then C-j then C-m (first message); subsequent may use Enter alone",
      "readiness_signals": [
        "'• Working' marker absent",
        "pane content byte-for-byte identical across N stable polls (filters transient redraws)"
      ],
      "readiness_strategy": "dual invariant: working-absent AND stable-content; single invariant false-passes ~1/3",
      "init_gates": [
        "launch with --no-alt-screen flag",
        "send '1' + Enter (trust banner dismissal)",
        "send Escape (hooks-review screen dismissal)"
      ],
      "auth_mount": {
        "required": ["~/.codex/ (dir)"],
        "skip_on_copy": ["tmp/", "log/", "logs/"]
      },
      "first_prompt_quirk": "C-j C-m required; single C-m places text but does not dispatch"
    },
    "gemini": {
      "submit_key_sequence": "TEXT then Enter (never C-m — unreliable through docker exec)",
      "readiness_signals": [
        "'Type your message or @path/to/file' prompt indicator visible"
      ],
      "readiness_strategy": "single prompt-indicator check sufficient",
      "init_gates": [
        "base image must be node:22 (node:18 crashes with undici File error)",
        "pre-patch ~/.gemini/settings.json: security.folderTrust.enabled = false"
      ],
      "auth_mount": {
        "required": ["~/.gemini/ (dir, OAuth credentials)"]
      },
      "first_prompt_quirk": "none after settings.json patch removes trust gate"
    }
  },

