// Paste these additions into the canonical tailnet policy.
// The LangFuse host advertises tag:langfuse; agent hosts advertise tag:agents.
// Tailscale HTTP Serve proxies only to 127.0.0.1:19431. Tailnet transport is
// WireGuard-encrypted; this avoids issuing a public HTTPS certificate.
{
  "tagOwners": {
    "tag:langfuse": ["autogroup:owner"]
  },
  "grants": [
    {
      "src": ["tag:agents"],
      "dst": ["tag:langfuse"],
      "ip": ["tcp:19431"]
    },
    {
      "src": ["autogroup:admin"],
      "dst": ["tag:langfuse"],
      "ip": ["tcp:19431"]
    }
  ]
}
