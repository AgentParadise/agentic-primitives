{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentRunResult",
  "description": "Terminal result of `itmux run`, emitted once after the run finishes (success, failure, timeout, or cancellation).",
  "type": "object",
  "required": [
    "result",
    "session_log"
  ],
  "properties": {
    "observability": {
      "description": "Aggregated status for configured observability exporters.",
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/ObservabilityBundle"
        },
        {
          "type": "null"
        }
      ]
    },
    "output_artifacts": {
      "description": "Paths to output artifacts collected from the workspace.",
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "result": {
      "$ref": "#/definitions/AgentRunOutcome"
    },
    "session_log": {
      "description": "The captured pane / session transcript.",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "AgentRunOutcome": {
      "description": "The success/failure verdict for a run (also carried by the terminal `session_end` event - see `AgentRunEventPayload::SessionEnd`).",
      "type": "object",
      "required": [
        "success",
        "summary"
      ],
      "properties": {
        "success": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ObservabilityBundle": {
      "description": "Aggregated observability export status attached to the final result.",
      "type": "object",
      "properties": {
        "exporters": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/ObservabilityExportReport"
          }
        }
      },
      "additionalProperties": false
    },
    "ObservabilityExportReport": {
      "description": "Final status for one configured observability exporter.",
      "type": "object",
      "required": [
        "kind",
        "status"
      ],
      "properties": {
        "error": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "events_exported": {
          "default": 0,
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "kind": {
          "type": "string"
        },
        "links": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/ObservabilityLink"
          }
        },
        "status": {
          "$ref": "#/definitions/ObservabilityExportStatus"
        },
        "target": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "ObservabilityExportStatus": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "ObservabilityLink": {
      "description": "A consumer-facing location for an exported observability view or artifact.",
      "type": "object",
      "required": [
        "label",
        "uri"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
